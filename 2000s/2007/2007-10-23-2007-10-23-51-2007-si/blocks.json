    "text": "(2)\u00be\u00f8\u00c6\u0095\u00ba \u00bc\u00fa\u00be\u00c6\u00b4 \u00a2\u00cd\u00ba\u00f8\u00be\u00e0\u00c4 \u00c9\u00ec \u00bc\u00e8\u00be\u00ef\u00c6\u00e0 \u00ef\u00c7\u00e5\u00e0\u00cd\u00ef\u00c8\u00e0 \u00ef\u00cc\u00e0\u00c9\u00ef\u00c6\u00e0\u00be\u00f8\u00c6\u00ea\u00a8\u00e0\u00ba\u00c9 \u00cc\u00e8\u0090\u00be\u00ea \u00c8\u00e6\u00c2\u00ea\u00c9\u00e5 \u00c9\u00ec \u00cc\u00e8\u00c6\u00f5\u00c4 \u00ba\u00e6\u00be\u00e6\u00ba\u00e0\u00ba\u00be\u00e0 \u00cd\u00b4 \u00a1\u00e5\u00c6\u00ea\u00da\u00ef\u008c\u00bc\u00ef\u00bc\u00c0\u00e5\u00da\u00ba\u00ef\u008a\u00be\u00e0\u00ba\u00eb\u00ef\u00c9\u00cd\u00e8 \u00ef\u00cc\u00e0\u00c9\u00e5 \u00be\u00f8\u00c6\u00ea\u00a8\u00e0\u00ba\u00e8\u00c6 \u00c0\u00e8\u00d6\u00be\u00c4\u00be\u00ea \u00c8\u00e6\u0094\u00c6 \u00c6\u00ea\u00ba\u00eb \u00a1\u00ba\u00c7 ,\u00be\u00f8\u00c6\u0095\u00ba \u00bc\u00fa\u00be\u00c6\u00b4 \u00a2\u00cd\u00ba\u00e8\u00be\u00e0 \u00c9\u00ec \u00bc\u00fa\u00be\u00ef\u00c6\u00e0 \u00a7\u00c9\u00ea\u00be\u00e0 \u00c3\u00eb\u00a8\u00e0\u00ba\u00f8 \u0097\u00bf\u00fa \u00be\u00f8\u00c6\u00c4 \u00cd\u00e5\u00ef\u00a8\u00e5\u00be\u00e0\u00ef\u00bc\u00e0\u00cc\u00e8\u00c9\u00c8\u00b4 \u00c9\u00b6\u00e5 \u00a1\u00b6\u00ea \u00c9\u00e5\u00cc\u00e8 \u00cc\u00cd\u00aa\u00ba \u00ef\u00be\u00e5\u00c9\u00be \u00be\u00f8\u00c6\u00c4 \u00cd\u00e5\u00ef\u00a8\u00e5\u00be\u00e0\u00ef\u00bc\u00e0\u00cc\u00e8 \u00c4\u00ba \u00a7\u00c9\u00ea\u00be\u00e0 \u00a1\u00e5\u00c6\u00ea\u00da\u00ef\u008c\u00bc \u00ef\u00bc\u00c0\u00e5\u00da\u00ba\u00ef\u008a\u00be\u00e0\u00ba\u00eb\u00c9 \u0097\u00cc\u00e8\u00be\u00e0 \u00ef\u00cc\u00e0\u00c9\u00ef\u00c6\u00cd\u00fa\u00be\u00f8\u00c6\u00ea\u00a8\u00e0\u00ba \u00a8\u00c7\u00be\u00ea \u00c8\u00e6\u0094\u00c6 \u00c6\u00ea\u00ba\u00eb \u00c6. \u00ba\u00c9 \u00bc \u00a7\u00c9\u00ea\u00be\u00e0 \u00ef\u00c7\u00e5\u00e0\u00cd\u00ef\u00c8\u00e0 \u00a8\u00e5\u00da\u00c6 \u00c4\u00b8\u00e0\u00b6\u00c8\u00c6\u00b4\u00c0\u00ba\u00e0\u00a8\u00c7\u00be\u00ea \u00c8\u00e6\u00c2\u00ec \u00bc\u00fa\u00be\u00ef\u00c6\u00be\u00e0 \u00a1\u00e5\u00c7\u008a\u00c3\u00c9 \u00ef\u008a \u00c0\u00be\u00ba \u00a8\u00f2\u00e8\u00c6\u00e5\u00ba\u00e0\u00c4\u00a8 \u00c9\u00be \u00bc\u00fa\u00be\u00ef\u00c6\u00be\u00e0\u00a1\u00c9\u00cc\u00be\u00e0 \u00c9\u00be \u00a7\u00c9\u00ea\u00be\u00e0\u00ef\u00aa\u00e0 \u00ef\u00cc\u00e0\u00c9\u00e5 \u00a8\u00e5\u00c8\u00c6 \u00a1\u00e5\u00b8\u00e0\u00b6\u00ea\u00c9 \u00c6\u00b4\u00ef\u00ba\u00e0 \u00c9\u00ec \u0097\u00ca\u00f2\u00e5\u00c4\u00c9\u00e6\u00b4\u00ea\u00c0\u00e0 \u00cc\u00cd\u00fa\u00ba \u00ef\u00cc\u00e0\u00c9\u00c6\u00a8\u00e0 \u00ef\u00c8\u00cc \u00aa\u00b8\u00be\u00e0 \u00aa\u00be\u00ea \u00c8\u00e6\u0094\u00c6 \u00c6\u00ea\u00ba\u00eb \u00c9\u00be\u00e0\u00ef\u00be\u00e0 \u00c6 :",
