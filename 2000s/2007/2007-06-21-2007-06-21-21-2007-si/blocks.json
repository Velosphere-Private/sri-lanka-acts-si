    "text": "4.\u00ef\u008a \u00c0\u00be\u00ef\u00ba\u00e0 \u00cc\u00cd \u00ef\u00c9\u00be\u00ba\u00e0 \u00c6\u008a \u00c8\u00e8\u008d\u00ba \u00be\u00f9\u00ba\u00f8\u00c6\u00a8 \u0097\u0093\u0097\u00bd\u00e5\u00be\u00c9\u00c8\u00b4\u00c6\u00b4\u00ba\u00e0\u00c9 \u00c2\u00e6\u00e2\u00a8\u00eb \u00aa\u00fa\u00b8\u00ea\u008a \u00a1\u00e5\u00c7\u008a\u00c3 \u00a8\u00f8\u00d7\u00c4, \u00a8\u00f2\u00e8\u00c6\u00e5\u00ba\u00e0\u00c4\u00a8 \u00a8\u00f8\u00d7\u00c4 \u00cc\u00cd \u00c9\u00e6\u00cc\u00e9\u00c4, \u00a1\u00e6\u00c0\u00a1\u00e6\u00ba\u00f8\u00c9 \u00ef\u00cd\u00e5\u00e0 \u00be\u00e6\u00ba\u00f8\u00c9 \u00c4\u00ea\u00bc\u00c8\u00e0 \u00b8\u00c6\u00b4 \u00aa\u00e6\u00be\u00f9\u00c4 \u00ef\u00cd\u00e5\u00e0 \u00c8\u00c2\u00e5 \u00aa\u00e6\u00be\u00f9\u00c4, \u00c0\u00f2\u00bc\u00e5\u00be \u00cd\u00e5\u00c0\u00d6\u00ba\u00f1\u00e5\u00aa \u00c0\u00e8\u00ce\u00e8\u00aa\u00e6\u00be\u00f9\u00c4 \u00ef\u00cd\u00e5\u00e0 \u00a6\u00a8\u00ba\u00eb \u00a8\u00f8\u00d7\u00c4, \u00cc\u00e2\u00cc\u00e0\u00bb\u00e5\u00ef\u008c \u00a1\u00c7\u00c4\u00ea\u00bc\u00c8\u00e0 \u00a1\u00e5\u00ef\u00c6\u00e5\u00e0\u00b0\u00be\u00c6\u00a8\u00f8\u00d7\u00c4 \u00cc\u00cd \u00cc\u00e2\u00cc\u00e0\u00bb\u00e5\u00ef\u008c \u00c0\u00c7\u00c4\u00e5\u00da\u00bb \u00a2\u00b4\u00ea \u00a8\u00f8\u00d7\u00c4 \u00cc\u00bf\u00cd\u00e5 \u00a1\u00c9\u00ca\u00f1 \u00be\u00f8\u00c8\u00bd\u00c7\u00c6\u00be\u00e0 \u00cc\u00cd\u00ef\u00cc\u00e0\u00c9\u00a8\u00c6\u00be\u00e0 \u00ef\u00cc\u00e0\u00c9\u00ef\u00c6\u00e0 \u00be\u00f8\u00c7\u00ba \u00a8\u00f8\u00d7\u00c4, \u00ef\u00cc\u00e0\u00c9\u00ef\u00c6\u00e0 \u00be\u00f8\u00c6\u00ea\u00a8\u00e0\u00ba \u00a8\u00f8\u00d7\u00c4 \u00cc\u00cd \u00ef\u00cc\u00e0\u00c9\u00ef\u00c6\u00be\u00e0\u00ef\u00be\u00c7\u00c0\u00e9\u00c4 \u00bc \u00a1\u00e6\u00ba\u00eb\u00dd\u00c9, \u00cc\u00e2\u00cc\u00e0\u00bb\u00e5\u00ef\u008c \u00cc\u00e8\u00c6\u00dd \u00c4 \u00c0\u00c7\u00c4\u00e5\u00da\u00bb \u00ef\u00cd\u00e5\u00e0 \u00a2\u00be\u00e0 \u00c6\u008a\u00c0\u00c7\u00c4\u00e5\u00da\u00bb\u00c6\u00a8\u00e0 \u00ef\u00cd\u00e5\u00e0 \u00a2\u00b4\u00ea \u00a8\u00c7 \u00aa\u00e6\u00be\u00f9\u00c4 \u00cc\u00bf\u00cd\u00e5 \u00cc\u00cd \u00cc\u00e5\u00a8\u00e0\u00cb\u00e5\u00ba\u00e0 \u00a8\u00c7 \u00aa\u00e6\u00be\u00f9\u00c4\u00cc\u00bf\u00cd\u00e5 \u00a1\u00c9\u00ca\u00f1 \u00ef\u00cd\u00e5\u00e0 \u00ef\u00c6\u00e5\u00e0\u00aa\u00f1 \u00cc\u00e8\u00c6\u00f5 \u00a8\u00f2\u00e8\u00c6\u00e5, \u00a8\u00c7\u00e6\u00b8\u00ea \u00cc\u00cd \u00ef\u00bc\u00e0 \u00a8\u00f8\u00d7\u00ef\u008a, \u00a2\u00b4\u00ea\u00a8\u00f8\u00d7\u00ef\u008a \u00cc\u00cd \u00a8\u00f2\u00e8\u00c6\u00e5\u00ba\u00e0\u00c4\u00a8 \u00a8\u00f8\u00d7\u00ef\u008a \u00c2\u00c8\u00c6 \u00cc\u00e2\u00cc\u00e0\u00bb\u00e5\u00c9\u00b4 \u00a1\u00e6\u00ba\u00e0\u00ef\u00ba\u00e0 \u00c6.",
