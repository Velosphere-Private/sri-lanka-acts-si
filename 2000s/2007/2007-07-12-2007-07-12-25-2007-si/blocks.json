    "text": "(\u00a1\u00e6) \u00cc\u00e9\u00c4\u00e5\u00cc\u00cd\u00fa\u00ba \u00c8\u00e2\u00a8\u00e5 \u00ef\u00cd\u00e5\u00e0\u00b4\u00c8\u00e0 \u00cc\u00e2\u00cc\u00e0\u00bb\u00e5\u00ef\u008c \u00ef\u00cc\u00e0\u00c9\u00ef\u00c6\u00be\u00e0 \u00a2\u00c9\u00ba\u00e0 \u00d1\u00c4\u00b4 \u00ef\u00ba\u00e5\u00e0\u00c7\u00e5\u00aa\u00be\u00e0\u00be\u00e5, (\u00a1) \u00ef\u00d8\u00bc\u00ef\u00c6\u00e0 \u00cc\u00bf\u00cd\u00be\u00e0 \u00c6\u008a \u00be\u00f8\u00c8\u00bd\u00c7\u00c6\u00a8\u00eb \u00ef\u00cd\u00e5\u00e0 \u00ef\u00cc\u00e0\u00c9\u00a8\u00c6\u00a8\u00eb \u0097\u00cc\u00e8\u00be\u00e0\u00cc\u00e9\u00c4\u00e5\u00cc\u00cd\u00fa\u00ba \u00c8\u00e2\u00a8\u00e5 \u00ef\u00cd\u00e5\u00e0\u00b4\u00c8\u00e0 \u00cc\u00e2\u00cc\u00e0\u00bb\u00e5\u00ef\u008c \u00ef\u00cc\u00e0\u00c9\u00c6 \u00a7\u00cd\u00ea\u00b4 \u00c0\u00e8\u00d6\u00be\u00e6\u00e4\u00ef\u008a \u00cd\u00e6\u00a8\u00f8\u00c6\u00e5\u00c9\u00c0\u00e8\u00ce\u00e8\u00c2\u00bf \u00a7\u00cd\u00ea\u00b4 \u00bc\u00e6\u00be\u00ea\u008a \u00f3\u00be\u00e0 \u00bc\u00fa\u00be\u00ef\u00c6\u00e0 \u00cc\u00e8\u00b4 \u00c4\u00e5\u00cc \u00ba\u00eb\u00be\u00a8 \u00a8\u00e5\u00c8\u00c6\u00a8\u00e0 \u00a1\u00e6\u00ba\u00eb\u00ce\u00ba \u00a6\u00c4\u00ef\u00ba\u00e5\u00e0\u00c7\u00e5 \u00aa\u00e6\u00be\u00f9\u00c4 \u00a8\u00ce \u00cd\u00e6\u00a8\u00f8 \u00c6. \u00be\u00f8\u00c8\u00bd\u00c7\u00c6\u00a8\u00eb \u00ef\u00cd\u00e5\u00e0 \u00ef\u00cc\u00e0\u00c9\u00a8\u00c6\u00a8\u00eb \u00c0\u00e8\u00d6\u00be\u00c4\u00be \u00c8\u00bc\u00ef\u00cc\u00e0\u00c9\u00c6 \u00c3\u00e5\u00c7 \u00ef\u00be\u00e5\u00aa\u00e6\u00be\u00f9\u00c4\u00b4 \u00cc\u00e0\u00c9\u00a8\u00f9\u00c6 \u00ef\u00ba\u00e5\u00e0\u00c7\u00e5 \u00aa\u00e6\u00be\u00f9\u00c4 \u00a8\u00f2\u00e8\u00c6\u00e5\u00ba\u00e0\u00c4\u00a8 \u00a8\u00c7\u00c6\u00fa \u00be\u008a,\u00a1\u00c4\u00e5\u00ba\u00f1 \u00c4\u00b8\u00e0\u00b6\u00c8\u00ef\u00c6\u00e0 \u00a1\u00be\u00ea\u00c4\u00ba\u00c6 \u00a1\u00e6\u00ba\u00f8\u00c9, \u00ba\u00ba\u00e0 \u00a8\u00e5\u00da\u00c6 \u00cc\u00bf\u00cd\u00e5 \u00a8\u00f2\u00e8\u00c6\u00e5\u00ba\u00e0\u00c4\u00a8 \u00a8\u00c7\u00be\u00ea\u00c8\u00e6\u0094\u00c6 \u00cd\u00e6\u00a8\u00f8 \u00cc\u00e0\u00ef\u008c\u0083\u00af\u00e5\u00ef\u00c9\u00be\u00e0 \u0097\u00ca\u00f2\u00e5\u00c4 \u00aa\u00e6\u00be\u00e0\u00d1\u00ef\u008a \u00ef\u00c6\u00e5\u00e0\u00b0\u00be\u00e5 \u00a8\u00f2\u00c4\u00c6\u00a8\u00e0 \u00c6\u00b4\u00ef\u00ba\u00e0\u00a7\u00cd\u00ea\u00b4 \u00c9\u00be\u00e0\u00bc\u00fa \u00c4\u00ea\u00bc\u00c8\u00e0 \u00ef\u00aa\u00c9\u00be\u00ea \u00c8\u00e6\u0094\u00c6 \u00c6\u00ea\u00ba\u00eb \u00c6.",
