    "text": "(\u00a1\u00e7) \u00ef\u00cc\u00e0\u00c9\u00a8 \u00a1\u00da\u00bb\u00cc\u00e5\u00bd\u00a8 \u00a1\u00c7\u00c4\u00ea\u00bc\u00ef\u00c8\u00e0 \u00cc\u00e5\u00c4\u00e5\u00d4\u00a8\u00c6\u00a8\u00eb \u00c9\u00be\u00e0\u00be\u00e5 \u00c9\u00ec \u00bc (\u00a1\u00e6)\u00ef\u00d8\u00bc\u00ef\u00c6\u00e0 \u00cc\u00bf\u00cd\u00be\u00e0 \u00cc\u00e0\u00ef\u008c\u0083\u00af\u00e5\u00ef\u00c9\u00be\u00e0 \u0097\u00ca\u00f2\u00e5\u00c4 \u00aa\u00e6\u00be\u00e0\u00d1\u00ef\u008a \u00ef\u00c6\u00e5\u00e0\u00b0\u00be\u00e5 \u00a8\u00f2\u00c4\u00c6 \u00c6\u00b4\u00ef\u00ba\u00e0\u0097\u00ca\u00f2\u00e5\u00c4 \u00aa\u00be\u00e0\u00be\u00e5 \u00c9\u00ec \u00bc, \u00c6\u008a \u00be\u00f8\u00c8\u00bd\u00c7\u00c6\u00a8\u00eb \u00ef\u00cd\u00e5\u00e0 \u00ef\u00cc\u00e0\u00c9\u00a8\u00c6\u00a8\u00eb, \u00a6\u00c4 \u00cc\u00e0\u00ef\u008c\u0083\u00af\u00e5\u00ef\u00c9\u00be\u00e0\u0097\u00ca\u00f2\u00e5\u00c4 \u00aa\u00e6\u00be\u00e0\u00d1\u00ef\u008a \u00ef\u00c6\u00e5\u00e0\u00b0\u00be\u00e5 \u00a8\u00f2\u00c4\u00c6 \u00c6\u00b4\u00ef\u00ba\u00e0 \u00c9\u00be\u00e0\u00bc\u00fa \u00c8\u00c2\u00e5\u00ef\u00aa\u00be \u0097\u00ca\u00f2\u00e5\u00c4\u00aa\u00e6\u00be\u00f9\u00ef\u00c4\u00be\u00e0 \u00c0\u00cc\u00ea\u00c9, \u00ef\u00cc\u00e0\u00c9\u00a8 \u00a1\u00da\u00bb\u00cc\u00e5\u00bd\u00a8 \u00a1\u00c7\u00c4\u00ea\u00bc\u00ef\u00c8\u00e0 \u00a6\u00c4 \u00be\u00f8\u00c8\u00bd\u00c7\u00c6\u00e5\u00ef\u00aa\u00e0 \u00ef\u00cd\u00e5\u00e0\u00ef\u00cc\u00e0\u00c9\u00a8\u00c6\u00e5\u00ef\u00aa\u00e0 \u00ef\u00c0\u00f0\u00bc\u00e0\u00aa\u00c8\u00e8\u00a8 \u00aa\u00fa\u00b8\u00ea\u00ef\u008a \u00c2\u00e6\u00c7\u00b4 \u00a1\u00e6\u00ba\u00f8 \u00cc\u008a\u00c0\u00ec\u00da\u00b8 \u00c4\u00ea\u00bc\u00c8, 1958\u00a1\u00e2\u00a8 15 \u00bc\u00c7\u00be \u00ef\u00cc\u00e0\u00c9\u00a8 \u00a1\u00da\u00bb\u00cc\u00e5\u00bd\u00a8 \u00a1\u00c7\u00c4\u00ea\u00bc\u00c8\u00e0 \u00c0\u00be\u00ef\u00ba\u00e0 23 \u00c9\u00be \u00c9\u00aa\u00be\u00e0\u00ba\u00f8\u00ef\u00c6\u00e0(1) \u00c9\u00be \u00a4\u00c0\u00c9\u00aa\u00be\u00e0\u00ba\u00f8\u00ef\u00c6\u00e0 (\u00a3) \u00ef\u00d8\u00bc\u00ef\u00c6\u00e0 (ii) \u00c9\u00be \u00a1\u00be\u00ea-\u00ef\u00d8\u00bc\u00ef\u00c6\u00e0 \u0097\u0093\u0097\u00bd\u00e5\u00be\u00c0\u00f2\u00a8\u00e5\u00c7\u00c9, \u00c0\u00f2\u00e5\u00ef\u00c6\u00e5\u00e0\u00aa\u00fa\u00a8\u00c9 \u00cd\u00e6\u00a8\u00f8\u00ba\u00e5\u00a8\u00e0 \u00a2\u00a8\u00e0\u00c4\u00be\u00f8\u00be\u00e0 \u00a6\u00c4 \u00be\u00f8\u00c8\u00bd\u00c7\u00c6\u00e5\u00b4 \u00ef\u00cd\u00e5\u00e0\u00ef\u00cc\u00e0\u00c9\u00a8\u00c6\u00e5\u00b4 \u00ef\u00aa\u00c9\u00be\u00ea \u00c8\u00e6\u0094\u00c6 \u00c6\u00ea\u00ba\u00eb \u00c6.",
