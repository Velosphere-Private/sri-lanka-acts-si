    "text": "(5) \u00c3\u00e5\u00b8\u00e0\u00b6\u00e5\u00aa\u00e5\u00c7\u00ef\u00c6\u00e0 \u00ef\u00c8\u00e0\u00a8\u008a\u00c9\u00c7\u00c6\u00e5 \u0097\u00cc\u00e8\u00be\u00e0 \u00a1\u00c4\u00e5\u00ba\u00f1 \u00c4\u00b8\u00e0\u00b6\u00c8\u00ef\u00c6\u00e0 \u00c0\u00ec\u00da\u00c9\u00a1\u00be\u00ea\u00c4\u00ba\u00c6 \u00a1\u00e6\u00ba\u00f8\u00c9, \u00c8\u00e2\u00a8\u00e5 \u00ef\u00cd\u00e5\u00e0\u00b4\u00c8\u00e0 \u00cc\u00e2\u00cc\u00e0\u00bb\u00e5\u00ef\u008c \u00a2\u00ba\u00f8\u00d6 \u00c9\u00c7\u00b8\u00e9\u00c6 \u00ef\u00a8\u00e5\u00b4\u00cc\u00e0 \u00cc\u00e5\u00c4\u00e5\u00be\u00f1\u00ef\u00a8\u00e5\u00b4\u00cc\u00e0 \u00c2\u00c9\u00b4 \u00c0\u00d6\u00c9\u00da\u00ba\u00be\u00c6 \u00ef\u00a8\u00e5\u00b4 \u00a6\u00c4 \u00ef\u00a8\u00e5\u00b4\u00cc\u00e0 \u00ef\u00cd\u00e5\u00e0 \u00a6\u00c4 \u00ef\u00a8\u00e5\u00b4\u00cc\u00e0\u00c9\u00c8\u00c6\u008a \u00a1\u00c6\u00fa\u00ba\u00f8\u00c9\u00e5\u00cc\u00e8\u00a8\u008a \u00c2\u00e6\u00cd\u00e6\u00c7 \u00a8\u00c7\u00be\u00ea \u00c8\u00e6\u0094\u00c6 \u00cd\u00e6\u00a8\u00f8 \u00be\u00c4\u00ea\u00ba\u00e0, \u00a6\u00c4 \u00ef\u00a8\u00e5\u00b4\u00cc\u00e0\u00c9\u00c8\u00e8\u00be\u00e0\u00cc\u00e8\u00c6\u00c6\u00b4 \u00bc\u00cd\u00c6\u00a8 \u00c0\u00f2\u00ba\u00f8\u00ca\u00ba\u00c6\u00a8\u00e0 \u00be\u00f8\u00c6\u0095\u00ba \u00bc\u00fa\u00be\u00c6\u00b4 \u00ef\u00c0\u00c7\u00e5\u00ba\u00eb\u00c9 \u00c4 \u00c9\u00ec \u00bc\u00fa\u00be\u00ef\u00c6\u00e0 \u00bc\u00fb\u00c8\u00e2\u00a8\u00e5 \u00ef\u00cd\u00e5\u00e0\u00b4\u00c8\u00e0 \u00cc\u00e2\u00cc\u00e0\u00bb\u00e5\u00ef\u008c \u00ef\u00cc\u00e0\u00c9\u00ef\u00c6\u00e0 \u00be\u00f8\u00c6\u00ea\u00a8\u00e0\u00ba\u00c9 \u00cc\u00e8\u0090 \u00ef\u00cc\u00e0\u00c9\u00e5 \u00be\u00f8\u00c6\u00ea\u00a8\u00e0\u00ba\u00c6\u00be\u00e0\u00a1\u00ba\u00c7 \u00a1\u00c4\u00e5\u00ba\u00f1\u00c9\u00c7\u00c6\u00e5 \u0097\u00cc\u00e8\u00be\u00e0 \u0097\u00bd\u00e5\u00be\u00c6 \u00a8\u00c7\u00be\u00ea \u00c8\u00c2\u00be \u00a1\u00e5\u00a8\u00e5\u00c7\u00c6\u00b4 \u00ef\u00c2\u00bc\u00e5 \u00ef\u00bc\u00be\u00ea\u00c8\u00e6\u0094\u00c6 \u00c6\u00ea\u00ba\u00eb \u00c6. \u00ba\u00c9 \u00bc, \u00a6\u00c4 \u00ef\u00a8\u00e5\u00b4\u00cc\u00e0 \u00a6\u00c4 \u00ef\u00cc\u00e0\u00c9\u00e5 \u00be\u00f8\u00c6\u00ea\u00a8\u00e0\u00ba\u00c6\u00be\u00e0\u00ef\u00aa\u00e0 \u00be\u0095\u00be\u00e0\u00ef\u00cc\u00e0\u00c9\u00a8 \u00a1\u00da\u00bb\u00cc\u00e5\u00bd\u00a8 \u00a1\u00c7\u00c4\u00ea\u00bc\u00c8 \u00cc\u00cd \u00ef\u00cc\u00e0\u00c9\u00e5 \u00be\u00f8\u00c6\u00ea\u00a8\u00e0\u00ba\u00c6\u00be\u00e0\u00ef\u00aa\u00e0 \u00c3\u00e5\u00c7 \u00a1\u00c7\u00c4\u00ea\u00bc\u00c8\u00cc\u00ba\u00eb \u00a8\u00c7\u00be\u00ea \u00c8\u00e6\u0094\u00c6 \u00c6\u00ea\u00ba\u00eb \u00c6.",
