    "text": "\u00a6\u00ef\u00cc\u00e0 \u00c9\u00ea\u00c9 \u00bc, 1987 \u00a1\u00e2\u00a8 23 \u00bc\u00c7\u00be \u00c7\u00e5\u00b0\u00f1 \u00cc\u00e2\u00cc\u00e0\u00bb\u00e5 \u00ef\u00cd\u00e5\u00e0 \u00a1\u00e5\u00b8\u00e0\u00b6\u00ea\u00c9\u00b4 \u00a1\u00c6\u00ba\u00e0\u00c9\u00f1\u00e5\u00c0\u00e5\u00c7 \u00a1\u00e5\u00c6\u00ba\u00be \u00ef\u00c0\u00e5\u00f3 \u00cc\u00c4\u00e5\u00aa\u008a \u00c2\u00c9\u00b4 \u00c0\u00d6\u00c9\u00da\u00ba\u00be\u00c6 \u00a8\u00f8\u00d7\u00ef\u008a \u00c0\u00be\u00ef\u00ba\u00e0 2\u00c9\u00be \u00c9\u00aa\u00be\u00e0\u00ba\u00f8\u00ef\u00c6\u00e0 (3) \u00c9\u00be \u00a4\u00c0\u00c9\u00aa\u00be\u00e0\u00ba\u00f8\u00ef\u00c6\u00e0 \u0097\u0093\u0097\u00bd\u00e5\u00be \u00be\u00f8\u00c6\u0095\u00ba \u00bc\u00fa\u00be\u00c6\u00b4\u00ef\u00c0\u00c7\u00e5\u00ba\u00eb\u00c9 \u00c4 \u00c9\u00ec \u00bc\u00fa\u00be\u00ef\u00c6\u00e0 \u00bc\u00fb \u00c8\u00e2\u00a8\u00e5 \u00ef\u00cd\u00e5\u00e0\u00b4\u00c8\u00e0 \u00cc\u00e2\u00cc\u00e0\u00bb\u00e5\u00c9 \u0097\u00cc\u00e8\u00be\u00e0 \u00bc\u00c7\u00be \u00c8\u00bc \u00cc\u00e5\u00c4\u00e5\u00be\u00f1\u00cc\u00cd \u00c9\u00c7\u00b8\u00e9\u00c6 \u00ef\u00a8\u00e5\u00b4\u00cc\u00e0, \u00cc\u00ba\u00eb \u00a8\u00f8\u00d7\u00c4\u00b4 \u00a1\u00bc\u00e5\u00ce \u00ef\u00be\u00e5\u0097\u00c6 \u00c6\u00ea\u00ba\u00eb \u00a1\u00ba\u00c7, \u00a6\u00e0 \u00a1\u00be\u00ea\u00c9\u00a6\u00c4 \u00bc\u00fa\u00be\u00ef\u00c6\u00e0 \u00bc\u00fb \u00a1\u00bc\u00e5\u00ce\u00c9 \u00ba\u00f8\u00c2\u00ec \u00cc\u00e5\u00c4\u00e5\u00be\u00f1 \u00cc\u00cd \u00c9\u00c7\u00b8\u00e9\u00c6 \u00ef\u00a8\u00e5\u00b4\u00cc\u00e0 \u00c9\u00f1\u00ea\u00cd\u00c6 \u00be\u00f8\u00c6\u0095\u00ba\u00bc\u00fa\u00be\u00ef\u00c6\u00e0 \u00cc\u00e8\u00b4 \u00c2\u00c8\u00c0\u00c9\u00ba\u00e0\u00c9\u00be \u00c0\u00d6\u00bc\u00fa \u00cc\u00e9\u00c4\u00e5\u00cc\u00cd\u00fa\u00ba \u00c8\u00e2\u00a8\u00e5 \u00ef\u00cd\u00e5\u00e0\u00b4\u00c8\u00e0 \u00cc\u00e2\u00cc\u00e0\u00bb\u00e5\u00ef\u008c \u00ef\u00a8\u00e5\u00b4\u00cc\u00e0\u00c9\