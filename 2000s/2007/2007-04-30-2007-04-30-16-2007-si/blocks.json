    "text": "\u00ef\u00c8\u00cc \u00be\u008a \u00a8\u00c7\u00be \u00ef\u00c8\u00cc \u00be\u00f8\u00c6\u00c4 \u00a8\u00c7\u0095\u00be\u00e0 \u00bd\u00ea\u00c7\u00c6 \u00cd\u00e8\u00cc\u00e0\u00a8\u00c7\u00be\u00c8\u00bc \u00cc\u00c3\u00e8\u00a8\u00c6\u00e5\u00ef\u00aa\u00e0 \u00be\u00e5\u00c4 \u00ef\u00c6\u00e5\u00e0\u00b0\u00be\u00e5 \u00c0\u00ba\u00f2\u00c6 \u00a2\u00bc\u00fa\u00d6\u00c0\u00ba\u00e0 \u00a8\u00ce\u00c0\u00e8\u00ce\u00e8\u00aa\u00ba\u00e0 \u00ef\u00bc\u00e0\u00ca\u00c0\u00e5\u00c8\u00be \u00c0\u00a8\u00e0\u00cb\u00ef\u00c6\u00e0 \u00ef\u00c8\u00e0\u00a8\u008a\u00c9\u00c7\u00c6\u00e5 \u00ef\u00c9\u00ba \u00ef\u00cd\u00e5\u00e0\u00cc\u00e0\u00c9\u00e5\u009e\u00be \u00a8\u00b8\u00e0\u00b6\u00e5\u00c6\u00ef\u008a \u00a8\u00b8\u00e0\u00b6\u00e5\u00c6\u008a \u00be\u00e5\u00c6\u00a8\u00c6\u00e5 \u00ef\u00c9\u00ba \u00a6\u00c4\u00a8\u00c7\u00e6\u00b8 \u00c0\u00e8\u00ce\u00e8\u00c2\u00bf\u00c9 \u00ef\u00ba\u00e0\u00d7\u008a\u00c3\u00e5\u00c7 \u00be\u00f8\u00c8\u00bd\u00c7\u00c6\u00e5 \u0097\u00cc\u00e8\u00be\u00e0 \u00bc\u00e6\u00be\u00ea\u008a\u00bc\u00fa\u00c6 \u00c6\u00ea\u00ba\u00eb \u00c6. \u00a6\u00c4 \u00c0\u00ea\u00c7\u00c0\u00e0\u00c0\u00e5\u00b6\u00ea\u00c9 \u00c0\u00e8\u00c7\u00d1\u00c4 \u00cc\u00bf\u00cd\u00e5 \u00cc\u00ea\u00f3\u00cc\u00ea\u00a8\u008a\u00a1\u00e6\u00ba\u00f8 \u00ba\u00e6\u00be\u00e6\u00ba\u00e0\u00ba\u00a8\u00eb \u00be\u00f8\u00ca\u00e0\u008e\u00ba \u00a8\u00e5\u00c8\u00c6 \u00a1\u00e6\u00ba\u00eb\u00ce\u00ba \u00a6\u00c4\u00ef\u00c8\u00e0\u00a8\u008a\u00c9\u00c7\u00c6\u00e5 \u00ef\u00cd\u00e5\u00e0 \u00a8\u00b8\u00e0\u00b6\u00e5\u00c6\u008a \u00be\u00e5\u00c6\u00a8\u00c6\u00e5 \u0097\u00cc\u00e8\u00be\u00e0 \u00be\u008a\u00a8\u00c7\u00be\u00ea \u00c8\u00c2\u00be\u00e0\u00ef\u00be\u00e0 \u00be\u008a \u00cc\u00cd \u00a6\u00c4 \u00c0\u00ea\u00c7\u00c0\u00e0\u00c0\u00e5\u00b6\u00ea\u00c9 \u00c0\u00e8\u00c7\u00d1\u00c4 \u00cc\u00bf\u00cd\u00e5\u00be\u00e5\u00c4 \u00ef\u00c6\u00e5\u00e0\u00b0\u00be\u00e5 \u00a8\u00c7\u00be \u00c8\u00bc \u00ba\u00e6\u00be\u00e6\u00ba\u00e0\u00ba\u00e5 \u0097\u00cc\u00e8\u00be\u00e0\u00a1\u00c9\u00cc\u00e0\u00bb\u00e5\u00ef\u00c9\u00e5\u00e0\u008e\u00ba \u00c0\u00d6\u00bc\u00fa \u00a1\u00e5\u00b8\u00e0\u00b6\u00ea\u00a8\u00f2\u00c4 \u00c9\u00f1\u00c9\u00cc\u00e0\u00bb\u00e5\u00ef\u008c \u00cd\u00ba\u00e0\u00c9\u00be\u00a4\u00c0\u00ef\u00c8\u00e0\u00a9\u00be\u00ef\u00c6\u00e0 \u00bc\u00a8\u00e0\u00c9\u00e5 \u00a1\u00e6\u00ba\u00f8 \u00a1\u00a8\u00ee\u00ba\u00f8 \u00c0\u00ba\u00f2\u00c6 \u00a1\u00be\u00ea\u00c9 \u00bc\u00e8\u00c9\u00ea\u00c7\u00e6\u00c4\u00a8\u00e0\u00ef\u00cd\u00e5\u00e0 \u00c0\u00f2\u00ba\u00f8\u00b3\u00e5 \u00bc\u00fb\u00c4\u00a8\u00e0 \u00cc\u00e8\u00f3 \u00a8\u00c7 \u00a6\u00c4 \u00bc\u00e8\u00c9\u00ea\u00c7\u00e6\u00c4 \u00ef\u00cd\u00e5\u00e0 \u00c0\u00f2\u00ba\u00e8\u00b3\u00e5\u00c9\u00bc\u00a6\u00c4 \u00be\u00e5\u00c4\u00ef\u00c6\u00e5\u00e0\u00b0\u00be\u00e5 \u00a8\u00f8\u00d7\u00c4 \u00cc\u00c4\u00aa \u00a2\u00bc\u00fa\u00d6\u00c0\u00ba\u00e0 \u00a8\u00c7 \u00a1\u00e6\u00ba\u00e0\u00be\u008a,\u00ef\u00ba\u00e0\u00d7\u008a\u00c3\u00e5\u00c7 \u00be\u00f8\u00c8\u00bd\u00c7\u00c6\u00e5 \u0097\u00cc\u00e8\u00be\u00e0 \u00a1\u00bc\u00e5\u00ce \u00c0\u00ce\u00e5\u00ba\u00e0 \u00c0\u00e5\u00c8\u00be\u00a1\u00e5\u00c6\u00ba\u00be\u00ef\u00c6\u00e0 \u00cc\u00c3\u00fa\u00a8\u00c6\u00a8\u00eb \u00ef\u00c8\u00cc \u00a6\u00c4 \u00ba\u00e6\u00be\u00e6\u00ba\u00e0\u00ba\u00e5 \u00ef\u00ba\u00e5\u00e0\u00c7\u00e5\u00c0\u00ba\u00e0 \u00a8\u00c7 \u00aa\u00ba\u00e0 \u00ef\u00c8\u00cc \u00c0\u00f2\u00a8\u00e5\u00ca\u00c6\u00b4 \u00c0\u00ba\u00e0 \u00a8\u00c7\u00be\u00ea \u00c8\u00e6\u0094\u00c6\u00c6\u00ea\u00ba\u00eb \u00c6.",
