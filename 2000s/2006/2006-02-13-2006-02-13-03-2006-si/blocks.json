    "text": "\u00c0\u00e5\u00da\u00c8\u00e8\u00ef\u008a\u00be\u00e0\u00ba\u00eb\u00ef\u008c \u00cc\u00e8\u00e2\u00cd\u00c8 \u00c0\u00be\u00ba\u00e0 \u00ef\u00a8\u00b4\u00ea\u008a\u00c0\u00ba\u00e0\u00c9\u00c8 \u00cc\u00cd \u00c0\u00be\u00ba\u00e0\u00c9\u00c8 \u00c9\u00e5\u00da\u00cb\u00e8\u00a8 \u00bc\u00e5\u00c6\u00a8 \u0095\u00ce (\u00ef\u00bc\u00e0\u00ca\u00fb\u00c6) \u00c7\u00e6. 870 \u00a8\u00f8.(\u0097\u00ef\u00bc\u00e0\u00ca\u00e9\u00c6) \u00c7\u00e6. 1,160 \u00a8\u00f8. \u00a1\u00e2\u00a8 32, \u00b4\u00f2\u00e5\u00be\u00e0\u00cc\u00e0\u00c9\u00da\u00a8\u00e0\u00cc\u00e0 \u00c4\u00be\u00e0\u00bc\u00fa\u00c7\u00c6, \u00ef\u00c8\u00e5\u00e0\u00b4\u00cc\u00e0 \u00c0\u00e5\u00c7, \u00ef\u00a8\u00e5\u00ce\u00c5 01, \u00c7\u00b0\u00ef\u00c6\u00e0 \u00c0\u00f2\u00a8\u00e5\u00ca\u00be\u00a8\u00e5\u00da\u00c6\u00e5\u00e2\u00ca\u00ef\u00c6\u00e0 \u00a1\u0093\u00a8\u00e5\u00d7 \u00ef\u00c9\u00ba \u00cc\u00e7\u00c4 \u00c9\u00da\u00cb\u00c6\u00a8\u00c4 \u00ef\u00bc\u00cc\u00e6\u008a\u00c2\u00da \u00c4\u00cc 15 \u00c9\u00e6\u00be\u00f8 \u00bc\u00fa\u00be\u00b4 \u00ef\u00c0\u00c7 \u00bc\u00e5\u00c6\u00a8 \u00c4\u00ea\u00bc\u00c8\u00e0 \u00ef\u00aa\u00c9\u00e5 \u00c0\u00cc\u00ea\u00c9 \u00a6\u00ce\u00ef\u00c5\u00be \u00a6\u00a8\u00e0 \u00a6\u00a8\u00e0 \u00c9\u00da\u00cb\u00c6 \u00cc\u00bf\u00cd\u00e5 \u00a6\u00e0\u00c9\u00e5 \u00c8\u00c2\u00e5\u00aa\u00ba \u00cd\u00e6\u00a8\u00f8\u00c6.",
