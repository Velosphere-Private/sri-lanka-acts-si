    ],
    "text": "4.\u00c0\u00f2\u00bd\u00e5\u00be \u00c0\u00f2\u00b3\u00c0\u00e0\u00ba\u00f8\u00ef\u00c6\u00e0 299 \u00c9\u00be \u00c9\u00aa\u00be\u00e0\u00ba\u00f8\u00ef\u00c6\u00e0 (3) \u00c9\u00be \u00a4\u00c0\u00c9\u00aa\u00be\u00e0\u00ba\u00f8\u00ef\u00c6\u00e0\u201c\u00c0\u00e6\u00be \u00aa\u00fa\u00c6, \u00c9\u00c7\u00bc\u00a8\u00c7\u00e6 \u00a8\u00c7\u00be\u00ea \u00c8\u00e6\u00c2\u00ec \u00ba\u00e6\u00be\u00e6\u00ba\u00e0\u00ba\u00a8\u00eb\u00b4 \u00c4\u00c7\u00b8\u00e9\u00c6 \u00bc\u00b8\u00e0\u00b6\u00be \u00be\u00f8\u00c6\u00c4\u00c6\u00a8\u00e0\u00ef\u00cd\u00e5\u00e0 \u00bc\u00b6 \u00aa\u00e6\u00cc\u00e9\u00c4 \u00ef\u00cd\u00e5\u00e0 \u00c2\u00be\u00e0\u00bd\u00be\u00e5\u00aa\u00e5\u00c7\u00aa\u00ba \u00a8\u00f8\u00d7\u00c4 \u00bc \u00cc\u00cd\u00fa\u00ba\u00c9 \u00ef\u00cd\u00e5\u00e0 \u00c7\u00cd\u00fa\u00ba\u00c9, \u00a8\u00cc\u00c0\u00cd\u00c7 \u00bc\u00fb\u00ef\u008a \u00ef\u00cd\u00e5\u00e0 \u00bc\u00b8\u00e0\u00b6\u00be \u00be\u00f8\u00c6\u00c4\u00c6\u00be\u00e0 \u00a8\u00c7\u00be\u00ea \u00c8\u00e6\u00c2\u00ec \u0097\u00b4, \u00a6\u00e0 \u00bc\u00b8\u00e0\u00b6\u00be \u00be\u00f8\u00c6\u00c4\u00c6\u00c4\u00c7\u00b8\u00e9\u00c6 \u00bc\u00b8\u00e0\u00b6\u00be \u00be\u00e8\u00c6\u00c4\u00c6\u00a8\u00e0 \u00ef\u00cd\u00e5\u00e0 \u00bc\u00b6 \u00aa\u00e6\u00cc\u00e9\u00ef\u008a \u00ef\u00cd\u00e5\u00e0 \u00a8\u00cc \u00c0\u00cd\u00c7 \u00bc\u00fb\u00ef\u008a \u00ef\u00cd\u00e5\u00e0\u00bc\u00b8\u00e0\u00b6\u00be \u00be\u00f8\u00c6\u00c4\u00c6\u00a8\u00e0 \u00be\u008a, \u00ef\u00c4\u00cd\u00fa \u00a2\u00cd\u00ba \u00cc\u00bf\u00cd\u00be\u00e0 \u0097\u0093\u0097\u00bd\u00e5\u00be\u00c9\u00c8\u00b4 \u00c6\u00b4\u00ba\u00e0\u00c9,\u00a6\u00c6 \u00ef\u00be\u00e5\u00c0\u00c4\u00e5\u00c9 \u00a8\u00f2\u00e8\u00c6\u00e5\u00ba\u00e0\u00c4\u00a8 \u0097\u00c6 \u00c6\u00ea\u00ba\u00eb \u00c6. ;\u201d \u00c6\u00be \u00c9\u00ae\u00be \u00ef\u00c9\u00be\u00ea\u00c9\u00b4 \u201c\u00c0\u00e6\u00be\u00aa\u00fa\u00c6,\u00c9\u00c7\u00bc\u00a8\u00c7\u00e6 \u00a8\u00c7\u00be\u00ea \u00c8\u00e6\u00c2\u00ec \u00ba\u00e6\u00be\u00e6\u00ba\u00e0\u00ba\u00a8\u00eb\u00b4 \u00c4\u00c7\u00b8\u00e9\u00c6 \u00bc\u00b8\u00e0\u00b6\u00be \u00be\u00f8\u00c6\u00c4\u00c6\u00a8\u00e0 \u00ef\u00cd\u00e5\u00e0 \u00bc\u00b6\u00aa\u00e6\u00cc\u00e9\u00ef\u008a \u00ef\u00cd\u00e5\u00e0 \u00c2\u00be\u00e0\u00bd\u00be\u00e5\u00aa\u00e5\u00c7\u00aa\u00ba \u00a8\u00f8\u00d7\u00c4 \u00cc\u00cd\u00fa\u00ba\u00c9 \u00ef\u00cd\u00e5\u00e0 \u00c7\u00cd\u00fa\u00ba\u00c9 \u00bc\u00b8\u00e0\u00b6\u00be\u00be\u00f8\u00c6\u00c4\u00c6\u00a8\u00e0 \u00a8\u00c7\u00be\u00ea \u00c8\u00e6\u00c2\u00ec \u0097\u00b4 \u00a6\u00e0 \u00bc\u00b8\u00e0\u00b6\u00be \u00be\u00f8\u00c6\u00c4\u00c6 \u00c4\u00c7\u00b8\u00e9\u00c6 \u00bc\u00b8\u00e0\u00b6\u00be \u00be\u00f8\u00c6\u00c4\u00c6\u00a8\u00e0\u00ef\u00cd\u00e5\u00e0 \u00bc\u00b6 \u00aa\u00e6\u00cc\u00e9\u00ef\u008a \u00bc\u00b8\u00e0\u00b6\u00be \u00be\u00f8\u00c6\u00c4\u00c6\u00a8\u00e0 \u00be\u008a \u00ef\u00c4\u00cd\u00fa \u00a2\u00cd\u00ba \u00cc\u00bf\u00cd\u00be\u00e0 \u0097\u0093\u0097\u00bd\u00e5\u00be\u00c9\u00c8\u00b4 \u00c6\u00b4\u00ba\u00e0\u00c9 \u00a6\u00c6 \u00ef\u00be\u00e5\u00c0\u00c4\u00e5\u00c9 \u00a8\u00f2\u00e8\u00c6\u00e5\u00ba\u00e0\u00c4\u00a8 \u0097\u00c6 \u00c6\u00ea\u00ba\u00eb \u00c6.\u201d \u00c6\u00be \u00c9\u00ae\u00be \u00a1\u00e5\u00ef\u00bc\u00e0\u00ca\u00a8\u00f8\u00d7\u00ef\u00c4\u00be\u00e0 \u00a6\u00c4 \u00c9\u00aa\u00be\u00e0\u00ba\u00f8\u00c6 \u00ef\u00c4\u00c6\u00fa\u00be\u00e0 \u00cc\u00e2\u00ef\u00ca\u00e5\u00e0\u00bd\u00be\u00c6 \u00a8\u00c7\u00be\u00ea \u00c8\u00e6\u00ef\u0089.",
