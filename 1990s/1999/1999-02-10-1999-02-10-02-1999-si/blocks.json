    "text": "2.\u00ef\u008a \u00c0\u00be\u00ba \u00a8\u00f2\u00e8\u00c6\u00e5\u00ba\u00e0\u00c4\u00a8 \u00d1\u00c4 \u00a1\u00e5\u00c7\u008a\u00c3 \u00c9\u00be \u00bc\u00fa\u00be \u00cc\u00e8\u00b4 \u00cc\u00cd \u00a2\u00be\u00e0 \u00c0\u00cc\u00ea(\u00ef\u00c4\u00cd\u00fa \u0095\u00be\u00e0 \u00c4\u00ba\u00eb \u201c\u00cc\u0095\u00ba\u00f8\u00c6\u201d \u00c6\u00be\u00ea\u00ef\u00c9\u00be\u00e0 \u00cc\u00bf\u00cd\u00be\u00e0 \u00a8\u00c7\u00be\u00ea \u00c8\u00c2\u00be) \u00ca\u00f2\u00e9 \u00c8\u00e2\u00a8\u00e5\u00ef\u008c\u00a8\u00e6\u00c8\u00e0\u00c9\u00d6 \u00ef\u00bc\u00e0\u00c9\u00cc\u00e0\u00bb\u00e5\u00be\u00ef\u00c6\u00e0 \u00bc\u00e6\u00be\u00b4 \u00cc\u00e5\u00c4\u00e5\u00d4\u00a8\u00c6\u00be\u00e0\u00c9 \u00cc\u00e8\u0090\u00be \u00ba\u00e5\u00a8\u00e0 \u00ba\u00e6\u00be\u00e6\u00ba\u00e0\u00ba\u00be\u00e0\u00ef\u00cd\u00e5\u00e0 \u00ef\u00c4\u00c6\u00fa\u00be\u00e0 \u00cc\u00e2\u00cc\u00e0\u00bb\u00e5\u00c0\u00be\u00c6 \u00a8\u00c7\u00be\u00ea \u00c8\u00c2\u00be \u00cc\u00e2\u00cc\u00e0\u00bb\u00e5\u00c9\u00b4 \u0095\u00be\u00e0 \u00c4\u00ba\u00eb \u00cc\u00e5\u00c4\u00e5\u00d4\u00a8\u00c6\u00be\u00e0\u00c9\u00ca\u00ef\u00c6\u00be\u00e0 \u00a1\u00e6\u00ba\u00eb\u00ce\u00ba\u00e0 \u00a8\u00c7\u00aa\u00be\u00ea \u00c8\u00c2\u00be \u00ba\u00e6\u00be\u00e6\u00ba\u00e0\u00ba\u00be\u00e0 (\u00ef\u00c4\u00cd\u00fa \u0095\u00be\u00e0 \u00c4\u00ba\u00eb \u201c\u00cc\u00e2\u00cc\u00e0\u00bb\u00e5\u00c9\u201d\u00c6\u00be\u00ea\u00ef\u00c9\u00be\u00e0 \u00cc\u00bf\u00cd\u00be\u00e0 \u00a8\u00c7\u00be\u00ea \u00c8\u00c2\u00be) \u201c\u00ca\u00f2\u00e9 \u00c8\u00e2\u00a8\u00e5\u00ef\u008c \u00a8\u00e6\u00c8\u00e0\u00c9\u00d6 \u00ef\u00bc\u00e0\u00c9\u00cc\u00e0\u00bb\u00e5\u00be\u00c6\u201d\u00c6\u00be \u00be\u00e5\u00c4\u00c6 \u00cd\u00e5 \u00a1\u00c3\u00fa\u00bd\u00e5\u00be\u00c6 \u00c6\u00b4\u00ef\u00ba\u00e0 \u00a1\u0097\u0083\u00d2\u00be\u00e0\u00be \u00c0\u00e6\u00c9\u00e6\u00ba\u00e0\u00c4\u00a8\u00e0 \u00a1\u00e6\u00ba\u00f8 \u00cc\u00e2\u00cc\u00e0\u00bb\u00e5\u00c9\u00a8\u00e0\u0097\u00c6 \u00c6\u00ea\u00ba\u00eb\u00c6. \u00ba\u00c9\u00bc \u00a6\u00e0 \u00cc\u00e2\u00cc\u00e0\u00bb\u00e5\u00c9 \u0097\u00cc\u00e8\u00be\u00e0 \u00cd\u00e5 \u00a6\u00c6\u00b4 \u0097\u00c7\u00e6\u00bc\u00e0\u00bd\u00c9 \u00bc \u00a6\u00a8\u00f9 \u00be\u00e5\u00c4\u00ef\u00c6\u00be\u00e0\u00cc\u00e8\u00c6\u00f5 \u00a1\u0093\u00a8\u00c7\u00b8\u00c6\u00be\u00e0\u00cd\u00fa \u00be\u00b6\u00ea \u00c0\u00c9\u00c7\u00be\u00ea \u00c8\u00e6\u0094\u00c6 \u00cd\u00e6\u00a8\u00f8 \u00a1\u00ba\u00c7 \u00ef\u00c0\u00e5\u00f3 \u00c4\u00ea\u00f7\u00e5\u00c9\u00a8\u00e0\u00ba\u00c2\u00e5 \u00aa\u00e6\u00be\u00f9\u00c4\u00b4 \u00bc, \u00a6\u00c6 \u00c0\u00e5\u0097\u0083\u008e \u00a8\u00f8\u00d7\u00c4\u00b4 \u00bc, \u00ba\u00c4 \u00a8\u00e6\u00c4\u00e6\u00ba\u00e0\u00ba \u00c0\u00d6\u00bc\u00fa \u00a6\u00c6 \u00ef\u00c9\u00be\u00cc\u00e0\u00a8\u00f8\u00d7\u00c4\u00b4 \u00bc \u00c0\u00ec\u00da\u00b8 \u00c2\u00c8\u00c6 \u00cd\u00e5 \u00a1\u0093\u00a8\u00e5\u00c7\u00c6 \u00a6\u00c6\u00b4 \u00a1\u00e6\u00ba\u00e0\u00ef\u00ba\u00e0 \u00c6.",
