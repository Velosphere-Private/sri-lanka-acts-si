    "text": "2.\u00ef\u008a \u00c0\u00be\u00ba \u00a8\u00f2\u00e8\u00c6\u00e5\u00ba\u00e0\u00c4\u00a8 \u00d1\u00c4 \u00a1\u00e5\u00c7\u008a\u00c3 \u00c9\u00be \u00bc\u00fa\u00be \u00cc\u00e8\u00b4 \u00cc\u00cd \u00a2\u00be\u00e0 \u00c0\u00cc\u00ea(\u00ef\u00c4\u00cd\u00fa \u0095\u00be\u00e0 \u00c4\u00ba\u00eb \u201c\u00cc\u0095\u00ba\u00f8\u00c6\u201d \u00c6\u00be\u00ea\u00ef\u00c9\u00be\u00e0 \u00cc\u00bf\u00cd\u00be\u00e0 \u00a8\u00c7\u00be\u00ea \u00c8\u00c2\u00be) \u00ca\u00f2\u00e9 \u00c8\u00e2\u00a8\u00e5\u00ef\u008c\u00a8\u00e6\u00c8\u00e0\u00c9\u00d6 \u00ef\u00bc\u00e0\u00c9\u00cc\u00e0\u00bb\u00e5\u00be\u00ef\u00c6\u00e0 \u00bc\u00e6\u00be\u00b4 \u00cc\u00e5\u00c4\u00e5\u00d4\u00a8\u00c6\u00be\u00e0\u00c9 \u00cc\u00e8\u0090\u00be \u00ba\u00e5\u00a8\u00e0 \u00ba\u00e6\u00be\u00e6\u00ba\u00e0\u00ba\u00be\u00e0\u00ef\u00cd\u00e5\u00e0 \u00ef\u00c4\u00c6\u00fa\u00be\u00e0 \u00cc\u00e2\u00cc\u00e0\u00bb\u00e5\u00c0\u00be\u00c6 \u00a8\u00c7\u00be\u00ea \u00c8\u00c2\u00be \u00cc\u00e2\u00cc\u00e0\u00bb\u00e5\u00c9\u00b4 \u0095\u00be\u00e0 \u00c4\u00ba\u00eb \u00cc\u00e5\u00c4\u00e5\u00d4\u00a8\u00c6\u00be\u00e0\u00c9\u00ca\u00ef\u00c6\u00be\u00e0 \u00a1\u00e6\u00ba\u00eb\u00ce\u00ba\u00e0 \u00a8\u00c7\u00aa\u00be\u00ea \u00c8\u00c2\u00be \u00ba\u00e6\u00be\u00e6\u00ba\u00e0\u00ba\u00be\u00e0 (\u00ef\u00c4\u00cd\u00fa \u0095\u00be\u00e0 \u00c4\u00ba\u00eb \u201c\u00cc\u00e2\u00cc\u00e0\u00bb\u00e5\u00c9\u201d\u00c6\u00be\u00ea\u00ef\u00c9\u00be\u00e0 \u00cc\u00bf\u00cd\u00be\u00e0 \u00a8\u00c7\u00be\u00ea \u00c8\u00c2\u00be) \u201c\u00ca\u00f2\u00e9 \u00c8\u00e2\u00a8\u00e5\u00ef\u008c \u00a8\u00e6\u00c8\u00e0\u00c9\u00d6 \u00ef\u00bc\u00e0\u00c9\u00cc\u00e0\u00bb\u00e5\u00be\u00c6\u201d\u00c6\u00be \u00be\u00e5\u00c4\u00c6 \u00cd\u00fa \u00a1\u00c3\u00fa\u00bd\u00e5\u00be\u00c6 \u00c6\u00b4\u00ef\u00ba\u00e0 \u00a1\u0097\u008e\u00d8\u00be\u00e0\u00be \u00c0\u00e6\u00c9\u00e6\u00ba\u00e0\u00c4\u00a8\u00e0 \u00a1\u00e6\u00ba\u00f8 \u00cc\u00e2\u00cc\u00e0\u00bb\u00e