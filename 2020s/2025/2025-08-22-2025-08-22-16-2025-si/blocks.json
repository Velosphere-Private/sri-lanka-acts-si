    "text": "(2) \u0dc0\u0dd9\u0dd9\u0db1\u0dad\u0dca \u0dba\u0db8\u0dca \u0dbd\u0dd2\u0d9b\u0dd2\u0dad \u0db1\u0dd3\u0dad\u0dd2\u0dba\u0d9a \u0dc4\u0ddd\ufffd\u0ddd \u0dba\u0db8\u0dca \u0daf\u0dd0\u0dd0\u0db1\u0dca\u0dc0\u0dd3\u0db8\u0d9a, \u0db1\u0dd2\u0dc0\u0dda\u0dda\u0daf\u0db1\u0dba\u0d9a, \u0d9c\u0dd2\u0dc0\u0dd2\u0dc3\u0dd4\u0db8\u0d9a, \u0dc3\u0db1\u0dca\u0db1\u0dd2\u0dc0\u0dda\u0dda\u0daf\u0db1\u0dba\u0d9a, \u0d86\u0d9a\u0dd8\u0dd8\u0dad\u0dd2 \u0db4\u0dad\u0dca\u200d\u0dbb\u0dba\u0d9a, \u0dc0\u0dd9\u0dd9\u0db1\u0dad\u0dca \u0dc3\u0dcf\u0dcf\u0db0\u0db1 \u0db4\u0dad\u0dca\u200d\u0dbb\u0dba\u0d9a \u0dc4\u0ddd\ufffd\u0ddd \u0dbd\u0dda\ufffd\u0d9b\u0db1\u0dba\u0d9a \u201c\u0db4\u0dcf\u0dcf\u0dbd\u0d9a\u201d \u0dc3\u0dc4 \u201c\u0dbb\u0db6\u0dbb\u0dca \u0db4\u0dcf\u0dcf\u0dbd\u0d9a\u201d \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\ufffd\u0db1\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0db1 \u0dc3\u0dd1\u0dd1\u0db8 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0d9a\u0dca \u0db8, \u0db8\u0dda\u023c \u0db4\u0db1\u0dad \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dc0\u0dd3\u0db8 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0dc0\u0db1 \u0daf\u0dd2\u0db1\u0dba\u0dda\u024f \u0dc3\u0dd2\u0da7 \u0dc3\u0dc4 \u0d8a\u0da7 \u0db4\u0dc3\u0dd4\u0dc0 \u201c\u0dbb\u0db6\u0dbb\u0dca \u0dc3\u0d82\u0d82\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0daf\u0dd9\u0dd9\u0db4\u0dcf\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u023c\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda\u0dda \u0d85\u0db0\u0dca\u200d\u0dba\u0dba\u0d9a\u0dca\u0dc2-\u0da2\u0db1\u0dbb\u0dcf\u0dcf\u0dbd\u0dca\u0dc0\u0dbb\u0dba\u0dcf\u0dcf\u201d \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\ufffd\u0db1\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0db1 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0d9a\u0dca \u0dbd\u0dd9\ufffd\u0dc3 \u0d9a\u0dd2\u0dba\u0dc0\u0dcf\u0dcf \u0dad\u0dda\ufffd\u0dbb\u0dd4\u0db8\u0dca\u0d9c\u0db1\u0d