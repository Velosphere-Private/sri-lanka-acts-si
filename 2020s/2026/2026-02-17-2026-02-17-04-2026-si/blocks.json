    "text": "\u0d9c\u0dd9\ufffd\u0db1\u0dba\u0db1\u0dca\u0db1\u0db1\u0dca\u0da7, \u0dba\u0dcf\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dcf\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0db1\u0ddc\ufffd\u0ddc\u0dc0\u0db1 \u0db4\u0ddc\ufffd\u0ddc\u0daf\u0dd4 \u0d9c\u0dd9\ufffd\u0db1\u0dba\u0db1\u0dca\u0db1\u0db1\u0dca\u0da7, \u0dba\u0dcf\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dcf\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0db1\u0ddc\ufffd\u0ddc\u0dc0\u0db1 \u0db4\u0ddc\ufffd\u0ddc\u0daf\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dcf\u0dc4\u0d9a\u0dba\u0db1\u0dca\u0da7 \u0dc3\u0dc4 \u0d9a\u0db1\u0dca\u0da7\u0dda\u0dda\u0178\u0db1\u0dbb\u0dca \u0db8\u0dd9\ufffd\u0dc4\u0dd9\ufffd\u0dba\u0dd4\u200d\u200d\u0db8\u0dca\u0d9a\u0dbb\u0dd4\u0dc0\u200d\u200d\u0db1\u0dca\u0da7 \u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dcf\u0dc4\u0d9a\u0dba\u0db1\u0dca\u0da7 \u0dc3\u0dc4 \u0d9a\u0db1\u0dca\u0da7\u0dda\u0dda\u0178\u0db1\u0dbb\u0dca \u0db8\u0dd9\ufffd\u0dc4\u0dd9\ufffd\u0dba\u0dd4\u200d\u200d\u0db8\u0dca\u0d9a\u0dbb\u0dd4\u0dc0\u200d\u200d\u0db1\u0dca\u0da7 \u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb \u0dbd\u0db6\u0dcf\u0dcf\u0daf\u0dd3\u0db8\u0dda\u0dda\u023c \u0db4\u0db1\u0dad \u0dc3\u0d82\u0d82\u0dc1\u0ddd\ufffd\u0ddd\ufffd\u0db0\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0db4\u0dd2\u0dab\u0dd2\u0dc3 \u0daf\u0dbd\u0db6\u0dcf\u0dcf\u0daf\u0dd3\u0db8\u0dda\u0dda\u023c \u0db4\u0db1\u0dad \u0dc3\u0d82\u0d82\u0dc1\u0ddd\ufffd\u0ddd\ufffd\u0db0\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0db4\u0dd2\u0dab\u0dd2\u0dc3 \u0daf; \u0dc3\u0dc4 \u0d92 \u0dc4\u0dcf\u0dcf \u0dc3\u0dc4 \u0d92 \u0dc4\u0dcf\u0dcf \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0 \u0dc4\u0ddd\ufffd\u0ddd\ufffd \u0d8a\u0da7 \u0d86\u0db1\u0dd4\u0dc2\u0d82\u0d82\u0d9c\u0dd2\u0d9a \u0d9a\u0dbb\u0dd4\u0dab\u0dd4 \u0dc3\u0db3\u0dc4\u0dcf\u0dcf \u0dc0\u0dd2\u0db0\u0dd2\u0dc0\u0dd2\u0db0\u0dcf\u0dcf\u0db1 \u