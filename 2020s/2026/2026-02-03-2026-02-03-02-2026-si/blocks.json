    "text": "\u0d91\u0dd9\u0dc3\u0dca \u026c\u0dc0 \u0daf, \u0d89\u0dc4\u0dad \u026a\u01dd\u026a\u0db0\u0dcf\u0db1\u0dc0\u0dbd\u0da7 \u0d85\u01e9\u0d9a\u0dd6\u0dbd\u0dc0 \u0d85\u0db0\u0dca\u200d\u0dba\u0dba\u0db1 \u0d85\u0d82\u0dc1\u0dba\u0d9a \u0286\u0179\u0db1 \u0286\u0dba\u0265\u0db8 \u0288\u01d0\u0288\u0d9a\u023c\u0dbd\u01ae \u0dad\u0dd0\u0db1\u0dd0\u01ae\u0dad\u01e6 \u0d91\u0db8 \u0d85\u0db0\u0dca\u200d\u0dba\u0dba\u0db1 \u0d85\u0d82\u0dc1\u0dd9\u024f \u021d\u0db0\u0dcf\u0db1\u0dba\u0dcf \u0dd9\u0dbd\u0dc3 \u0d94\u026c\u01e6\u0dd9\u0118 \u01df\u0dbb \u0d9a\u0dcf\u0dbd \u0dc3\u023c\u021b\u0259\u0dab \u0d9a\u0dbb \u0d87\u01af \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0d9a \u01cf, \u0dc3\u0dc4 \u0d91\u0dc0\u0dd0\u01e7 \u0db4\u01ae\u026b\u0db8\u00fa \u0dc3\u0db3\u0dc4\u0dcf \u0288\u01d0\u0288\u0d9a\u023c\u0dbd\u01ae \u0dd9\u0dc0\u0db1\u01ae \u0dad\u0dd0\u0db1\u0dd0\u01ae\u0dad\u01e6 \u0dd9\u0db1\u0dcf\u0db8\u0dd0\u01af \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0d9a \u01cf, \u0d91\u0db8 \u0d85\u0db0\u0dca\u200d\u0dba\u0dba\u0db1 \u0d85\u0d82\u0dc1\u0dd9\u024f \u021d\u0db0\u0dcf\u0db1\u0dba\u0dcf \u0dd9\u0dbd\u0dc3 \u0d9a\u0263\u01e6 \u01df\u0dbb\u0dba \u0daf\u0dd0\u025f \u0dad\u0dd0\u0db1\u0dd0\u01ae\u0dad\u0d9a\u0dd4, \u0d92 \u0dad\u0dd0\u0db1\u0dd0\u01ae\u0dad\u0dcf\u0dd9\u0118 \u0d9a\u0dd0\u0db8\u0dd0\u01ae\u0dad \u0d87\u01af \u0dc0, \u0d91\u0db8 \u0d85\u0db0\u0dca\u200d\u0dba\u0dba\u0db1 \u0d85\u0d82\u0dc1\u0dd9\u024f \u021d\u0db0\u0dcf\u0db1 \u01df\u0dbb\u0dba\u0da7 \u0db1\u0dd0\u0dc0\u0dad \u0db4\u01ae \u0d9a\u0dbb\u01e9 \u0dbd\u0dd0\u022a\u0dba \u0dc4\u0dd0\u00fb \u0dba. \u0d92 \u0db1\u0dd0\u0dc0\u0dad \u0db4\u01ae \u00fb\u025d\u0db8 (1\u0d85) \u0d8b\u0db4\u0dc0\u0d9c\u01e6\u01af\u0dd9\u024f \u0daf\u00fa\u0dc0\u0dcf \u0d87\u01af \u0d9a\u0dcf\u0259\u0dba \u0db4\u0179\u0db4\u0dcf\u0179\u0dba\u0da7 \u0d85\u01e9\u0d9a\u0dd6\u0dbd\u0dc0 \u0286\u01d0 \u0d9a\u0dbb\u01e9 \u0dbd\u0dd0\u022a\u0dba \u0252\u01b1 \u0dba:",
